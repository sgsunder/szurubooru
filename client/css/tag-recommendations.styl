@import colors

div.tag-recommendations
    margin-top: 0.5em

    &:not(.loading).empty
        display: none

    .header
        margin: 0 0 0.2em 0
        font-size: 90%
        color: $inactive-link-color
        .fa-spinner
            visibility: hidden
            margin-left: 0.3em

    &.loading .header .fa-spinner
        visibility: visible

    ul
        list-style-type: none
        margin: 0
        padding: 0
        li
            margin: 0
            font-size: 90%
            line-height: 1.3
            white-space: nowrap
            overflow: hidden
            text-overflow: ellipsis
            a, span
                display: inline-block
                vertical-align: bottom
            .add-tag
                max-width: 12em
                overflow: hidden
                text-overflow: ellipsis

.darktheme div.tag-recommendations .header
    color: $inactive-link-color-darktheme
